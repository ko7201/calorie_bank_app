<div class="moji mx-auto max-w-2xl w-full px-4 py-10">
  <div class="rounded-2xl border border-white/30 bg-white/90 backdrop-blur-md shadow-xl p-8">
    <div class="mb-8">
      <h1 class="text-xl font-semibold text-gray-900">プロフィール情報</h1>
      <p class="mt-2 text-sm text-gray-600">プロフィール情報をもとに、あなたの1日の消費カロリーを計算します。</p>
      <p class="text-sm text-gray-600">あとで編集することができます。</p>
    </div>

    <% if @profile.errors.any? %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
        <p class="font-medium">入力内容をご確認ください</p>
        <ul class="mt-2 list-disc pl-5">
          <% @profile.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @profile, url: profile_path, local: true, class: "space-y-6" do |f| %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <%= f.label :age, "年齢", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :age, min: 0, max: 120,
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>

        <div>
          <%= f.label :gender, "性別", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :gender,
            [["男性", "male"], ["女性", "female"], ["その他", "other"]],
            { include_blank: "選択してください" },
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>

        <div>
          <%= f.label :height, "身長（cm）", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :height, step: 0.1, placeholder: "例：170.5",
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>

        <div>
          <%= f.label :weight, "体重（kg）", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :weight, step: 0.1, placeholder: "例：65.2",
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>

        <div class="sm:col-span-2">
          <%= f.label :activity_level, "活動レベル", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :activity_level,
            [["低い", "low"], ["普通", "middle"], ["高い", "high"]],
            { include_blank: "選択してください" },
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
          <div class="mt-3 rounded-lg bg-orange-50 p-3 text-xs text-gray-500 space-y-1">
            <p><span class="font-medium text-gray-700">低い：</span>デスクワーク中心で運動習慣がほぼない方</p>
            <p><span class="font-medium text-gray-700">普通：</span>デスクワーク中心だが、立ち仕事や通勤など日常の活動がある方</p>
            <p><span class="font-medium text-gray-700">高い：</span>立ち仕事が多い、または週数回の運動習慣がある方</p>
          </div>
        </div>

        <div>
          <%= f.label :weight_to_lose, "減量目標（kg）", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :weight_to_lose, step: 0.1, placeholder: "例：3.0",
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>

        <div>
          <%= f.label :rice_gram, "お茶碗1杯のご飯の量(g)", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :rice_gram, placeholder: "例：150",
            class: "mt-1 block w-full rounded-lg border-gray-300 bg-white shadow-sm focus:border-orange-400 focus:ring-orange-400" %>
        </div>
      </div>

      <div class="flex items-center justify-center pt-4">
        <%= f.submit "登録する",
          class: "w-full rounded-lg bg-orange-400 px-6 py-3 text-white font-semibold shadow-sm hover:bg-orange-300 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:ring-offset-2" %>
      </div>
    <% end %>
  </div>
</div>
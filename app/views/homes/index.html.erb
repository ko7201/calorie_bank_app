<div class="grid grid-cols-2 gap-3">
  <% if @calorie_records.present? %>
  <% @calorie_records.each do |record| %>
    <div class="border rounded p-4">
      <%= label "カロリー", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <h2 class="font-bold"><%= record.meal_type %></h2>
      <a href="#" class="text-sm text-blue-500">カロリー入力</a>
      <p><%= record.memo %></p>
      <p><%= record.calorie %> kcal</p>
    </div>
  <% end %>
    <% else %>
      <div class="border rounded p-4">
      <% @calorie_records.each do |record| %>
        <p>本日のカロリー記録はありません。</p>
      <% end %>
      </div>
    <% end %>
</div>
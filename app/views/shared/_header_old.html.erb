<div class="mb-6 rounded-2xl bg-white/80 backdrop-blur shadow-lg border border-black/5 p-6">

  <!-- 日付 -->
  <p class="text-sm text-gray-500">
    <%= l(Date.current) %>
  </p>

  <!-- 今日の貯金（主役） -->
  <div class="mt-3 text-center">
    <p class="text-sm text-gray-500">今日の貯金</p>
    <p class="text-4xl font-bold text-orange-500">
      <%= @calorie_saved %> kcal
    </p>
  </div>

  <!-- 累計 -->
  <div class="mt-4 text-center">
    <p class="text-xs text-gray-500">累計</p>

    <% if @total_saved_calorie >= 0 %>
      <p class="text-xl font-bold text-orange-500">
        <%= @total_saved_calorie %> kcal
      </p>
    <% else %>
      <p class="text-xl font-bold text-blue-500">
        <%= @total_saved_calorie %> kcal
      </p>
    <% end %>
  </div>

  <!-- サブ情報 -->
  <div class="mt-6 grid grid-cols-3 gap-3 text-center">
    <div>
      <p class="text-xs text-gray-500">消費</p>
      <p class="font-semibold"><%= @bmr %> kcal</p>
    </div>

    <div>
      <p class="text-xs text-gray-500">摂取</p>
      <p class="font-semibold"><%= @today_total %> kcal</p>
    </div>

    <div>
      <p class="text-xs text-gray-500">目標</p>
      <p class="font-semibold"><%= @calorie_goal %> kcal</p>
    </div>
  </div>

</div>
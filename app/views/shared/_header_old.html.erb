<div class="moji mb-6 rounded-2xl  text-white/90 shadow-lg border border-black/5 p-6">

  <!-- 日付 -->
  <p class="text-xl">
    <%= l(Date.current) %>
  </p>

  <!-- 今日の貯金（主役） -->
  <div class="mt-3 text-center">
    <p class="text-xl ">今日の貯金</p>
    <p class="text-4xl font-bold text-orange-500">
      <%= @calorie_saved %> kcal
    </p>
  </div>

  <!-- 累計 -->
  <div class="mt-4 text-center">
    <p class="text-xl">累計</p>

    <% if @total_saved_calorie >= 0 %>
      <p class="text-xl font-bold text-orange-500">
        <%= @total_saved_calorie %> kcal
      </p>
    <% else %>
      <p class="text-xl font-bold text-blue-500">
        <%= @total_saved_calorie %> kcal
      </p>
    <% end %>
  </div>

  <% progress =
    if @calorie_goal.to_i > 0
      (@total_saved_calorie.to_f / @calorie_goal.to_f * 100).clamp(0, 100)
    else
      0
    end
  %>

  <div class="mt-3">
    <div class="flex justify-between text-xl mb-1">
      <span>目標までの進捗</span>
      <span><%= progress.round %>%</span>
    </div>

  <div class="h-5 w-full rounded-full bg-gray-200">
    <div
      class="h-5 rounded-full bg-orange-400"
      style="width: <%= progress %>%">
    </div>
  </div>
  <!-- サブ情報 -->
  <div class="mt-6 text-xl grid grid-cols-3 gap-3 text-center">
    <div>
      <p>消費</p>
      <p class="font-semibold"><%= @bmr %> kcal</p>
    </div>

    <div>
      <p>摂取</p>
      <p class="font-semibold"><%= @today_total %> kcal</p>
    </div>

    <div>
      <p>目標</p>
      <p class="font-semibold"><%= @calorie_goal %> kcal</p>
    </div>
  </div>

</div>
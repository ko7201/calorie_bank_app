<div class="min-h-screen bg-cover bg-center relative">

  <!-- 背景画像（絶対配置で背景にする） -->
  <div class="absolute inset-0"
       style="background-image: url('<%= asset_path("mokume.jpg") %>');
               filter: brightness(1.0) saturate(3.2);"></div>
<section class="relative py-0 w-full pt-10">
  <div class="flex justify-center">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h1 class="hoge1 text-7xl sm:text-8xl font-bold text-white drop-shadow-lg">
          Calorie Bank
      </h1>
      <p class="moji mt-6 text-lg text-white">
        我慢の記録ではなく、工夫の記録。
        小さな節制を、今日の“貯金”に。
      </p>

    <div class="flex gap-6 justify-center mt-6">
      <%= link_to "ログイン", new_user_session_path,
        class: "inline-block px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-500" %>
      <%= link_to "新規登録", new_user_registration_path,
        class: "inline-block px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-500" %>
    </div>

    <%= button_to "Googleでログイン", user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false } %>
    <div class="flex flex-col items-center mt-4">
      <%= link_to "ゲストとして試してみる →",
        guest_sign_in_path, data: { "turbo-method": :post },
        class: "text-gray-600 text-base underline hover:text-gray-800" %>
      <p class="text-sm text-gray-900 mt-1 text-center">
        ※ゲストはログアウトするとデータがリセットされます
      </p>
    </div>
  </div>
</section>
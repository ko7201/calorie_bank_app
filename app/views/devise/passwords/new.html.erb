<div class="min-h-screen bg-cover bg-center flex items-center justify-center px-4">
  <div class="w-full max-w-sm rounded-2xl bg-white/85 backdrop-blur shadow-lg border border-black/5 p-6">

    <div class="text-center">
      <h2 class="text-2xl font-bold text-gray-900">
        パスワード再設定
      </h2>

      <p class="mt-3 text-sm text-gray-600 leading-6">
        登録済みのメールアドレスを入力してください。<br>
        パスワード再設定用のメールを送信します。
      </p>
    </div>

    <div class="mt-8">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700" %>

          <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "mt-2 w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm focus:border-orange-300 focus:ring-2 focus:ring-orange-100" %>
        </div>

        <div class="mt-6">
          <%= f.submit "再設定メールを送信",
            class: "w-full rounded-md bg-orange-300/90 px-6 py-2.5 text-white font-medium hover:bg-orange-200 active:bg-orange-400 transition shadow-sm" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 border-t pt-6 text-center text-sm space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
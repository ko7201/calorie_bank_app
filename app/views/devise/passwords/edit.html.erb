<div class="min-h-screen bg-cover bg-center flex items-center justify-center px-4">
  <div class="w-full max-w-sm rounded-2xl bg-white/85 backdrop-blur shadow-lg border border-black/5 p-6">

    <div class="text-center">
      <h2 class="text-2xl font-bold text-gray-900">
        パスワードを変更
      </h2>

      <p class="mt-3 text-sm text-gray-600 leading-6">
        新しいパスワードを入力してください。
      </p>
    </div>

    <div class="mt-8">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="space-y-5">
          <div>
            <%= f.label :password, "新しいパスワード", class: "block text-sm font-medium text-gray-700" %>

            <% if @minimum_password_length %>
              <p class="mt-1 text-xs text-gray-500">
                <%= @minimum_password_length %>文字以上で入力してください
              </p>
            <% end %>

            <%= f.password_field :password,
              autofocus: true,
              autocomplete: "new-password",
              class: "mt-2 w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm focus:border-orange-300 focus:ring-2 focus:ring-orange-100" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "block text-sm font-medium text-gray-700" %>

            <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "mt-2 w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm focus:border-orange-300 focus:ring-2 focus:ring-orange-100" %>
          </div>

          <div>
            <%= f.submit "パスワードを変更する",
              class: "w-full rounded-md bg-orange-300/90 px-6 py-2.5 text-white font-medium hover:bg-orange-200 active:bg-orange-400 transition shadow-sm" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-6 border-t pt-6 text-center text-sm space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>

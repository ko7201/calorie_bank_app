<div class="mx-auto max-w-2xl px-10 py-8">
  <h1 class="moji text-center text-white mb-6 text-3xl font-bold">カロリー履歴</h1>

  <% if @calorie_records.present? %>
    <% @calorie_records.group_by { |record| record.eat_date }.each do |date, records| %>
      <%= render "daily_records", date: date, records: records %>
    <% end %>
  <% else %>
    <div class="rounded-lg border bg-white p-6">
      <p class="text-sm text-gray-600">まだ記録がありません。</p>
    </div>
  <% end %>
</div>